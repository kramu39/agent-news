{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-news",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  "workers_dev": true,
  "preview_urls": true,
  "observability": { "enabled": false },

  "vars": {
    "ENVIRONMENT": "production",
    // Set to "false" to enable x402 paywall for past briefs; any other value (or omit) = free access
    "BRIEFS_FREE": "true"
  },

  // KV namespace — rate limiting and agent cache
  "kv_namespaces": [
    { "binding": "NEWS_KV", "id": "3b2ccbdc1fd5426ba72ed323e3407bdc" }
  ],

  // Durable Object binding — primary storage engine (SQLite)
  "durable_objects": {
    "bindings": [
      { "name": "NEWS_DO", "class_name": "NewsDO" }
    ]
  },

  // DO migrations — use new_sqlite_classes for SQLite-backed DOs
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["NewsDO"] }
  ],

  // Service bindings: worker-logs (RPC) and x402-sponsor-relay (RPC)
  "services": [
    { "binding": "LOGS", "service": "worker-logs-production", "entrypoint": "LogsRPC" },
    { "binding": "X402_RELAY", "service": "x402-sponsor-relay-production", "entrypoint": "RelayRPC" }
  ],

  // Smart Placement — moves Worker execution closer to the DO's storage location,
  // reducing Worker→DO network round-trip latency instead of running at the user's edge.
  "placement": { "mode": "smart" },

  // Static frontend assets.
  //   - binding: `env.ASSETS.fetch()` lets the Worker pull static files
  //     (used by the homepage SSR handler to transform public/index.html).
  //   - run_worker_first: ["/"]  → Worker intercepts ONLY the root. All other
  //     asset paths (sections, CSS, JS) still serve directly from the static
  //     asset server with zero Worker overhead. The `/` pattern is a literal
  //     exact match per Cloudflare docs — it does NOT match `/signals/abc`.
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/"]
  },

  /**
   * Secrets (set via `wrangler secret put`):
   * - MIGRATION_KEY — shared secret for POST /api/internal/migrate endpoints
   *
   * Per-environment secrets — run once with Cloudflare access:
   *   npx wrangler secret put MIGRATION_KEY --env staging
   *   npx wrangler secret put MIGRATION_KEY --env production
   */

  /**
   * Named environments — override top-level defaults for staging/production deploys.
   *
   * One-time staging setup (run with Cloudflare access, then update STAGING_KV_ID below):
   *   npx wrangler kv:namespace create NEWS_KV --env staging
   *   npx wrangler secret put MIGRATION_KEY --env staging
   *
   * Deploy commands:
   *   Staging:    npx wrangler deploy --env staging
   *   Production: npx wrangler deploy --env production  (or push to main via CI)
   */
  "env": {
    "staging": {
      "name": "agent-news-staging",
      "placement": { "mode": "smart" },

      "vars": {
        "ENVIRONMENT": "staging",
        // Set to "false" to enable x402 paywall for past briefs; any other value (or omit) = free access
        "BRIEFS_FREE": "true"
      },

      "kv_namespaces": [
        { "binding": "NEWS_KV", "id": "341f4de6834c4a908eb52f6cb556bbce" }
      ],

      "durable_objects": {
        "bindings": [
          { "name": "NEWS_DO", "class_name": "NewsDO" }
        ]
      },

      // Separate migration tag keeps staging DO independent of production
      "migrations": [
        { "tag": "v1-staging", "new_sqlite_classes": ["NewsDO"] }
      ],

      "services": [
        { "binding": "LOGS", "service": "worker-logs-staging", "entrypoint": "LogsRPC" },
        { "binding": "X402_RELAY", "service": "x402-sponsor-relay-staging", "entrypoint": "RelayRPC" }
      ],

      // No custom domain for staging — use workers.dev URL
      "assets": {
        "directory": "./public",
        "binding": "ASSETS",
        "run_worker_first": ["/"]
      }
    },

    "production": {
      "name": "agent-news",
      "placement": { "mode": "smart" },
      "workers_dev": true,
      "preview_urls": true,

      "vars": {
        "ENVIRONMENT": "production",
        // Set to "false" to enable x402 paywall for past briefs; any other value (or omit) = free access
        "BRIEFS_FREE": "true"
      },

      "kv_namespaces": [
        { "binding": "NEWS_KV", "id": "3b2ccbdc1fd5426ba72ed323e3407bdc" }
      ],

      "durable_objects": {
        "bindings": [
          { "name": "NEWS_DO", "class_name": "NewsDO" }
        ]
      },

      "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["NewsDO"] }
      ],

      "services": [
        { "binding": "LOGS", "service": "worker-logs-production", "entrypoint": "LogsRPC" },
        { "binding": "X402_RELAY", "service": "x402-sponsor-relay-production", "entrypoint": "RelayRPC" }
      ],

      "routes": [{ "pattern": "aibtc.news", "custom_domain": true }],
      "assets": {
        "directory": "./public",
        "binding": "ASSETS",
        "run_worker_first": ["/"]
      }
    }
  }
}
